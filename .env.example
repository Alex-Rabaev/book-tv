# Copy to .env and fill in. NEVER commit real values (AD-2: secrets server-side only).

# --- Backend (book-tv API) ---
# For local (non-Docker) dev use localhost; under docker-compose the api service
# overrides the host to `db`.
DATABASE_URL=postgresql+asyncpg://book:book@localhost:5432/booktv
JWT_SECRET=
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
CORS_ORIGIN=http://localhost:5173

# --- Frontend (Vite; only VITE_-prefixed vars reach the browser) ---
VITE_API_BASE_URL=http://localhost:8000
